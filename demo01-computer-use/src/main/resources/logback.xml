<configuration>
    <!-- 运行时间戳，用于日志文件名 -->
    <timestamp key="startTimestamp" datePattern="yyyyMMdd_HHmmss"/>

    <!-- 控制台输出 -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 文件输出：按运行时间戳创建日志文件 -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>${user.home}/.afs/logs/demo01_${startTimestamp}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Agent 和 LLM 的日志保持 DEBUG，方便看执行流程 -->
    <logger name="com.github.agent" level="DEBUG"/>

    <!-- OkHttp 日志关掉，避免刷屏 -->
    <logger name="okhttp3" level="WARN"/>

    <root level="WARN">
        <appender-ref ref="FILE"/>
    </root>
</configuration>
